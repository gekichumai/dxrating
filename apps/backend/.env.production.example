# PostgreSQL (used by docker-compose and DATABASE_URL)
POSTGRES_USER=dxrating
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dxrating

# Backend
DATABASE_URL=postgres://dxrating:CHANGE_ME@postgres:5432/dxrating
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
BETTER_AUTH_URL=http://YOUR_SERVER_IP
NODE_ENV=production
PORT=3000

# Optional: OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SECRET_KEY=
