{
  "name": "@gekichumai/dxrating",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsconfig": "workspace:*",
    "turbo": "^2.4.4"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@sentry/cli",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "protobufjs",
      "workerd"
    ]
  }
}