{
  "name": "@gekichumai/dxrating",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "devDependencies": {
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsconfig": "workspace:*",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": "25.9.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "happy-dom": ">=20.9.0",
      "flatted": ">=3.4.2",
      "effect": ">=3.21.2"
    },
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "@sentry/cli",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "prisma",
      "@prisma/engines",
      "protobufjs",
      "react-grab",
      "workerd"
    ]
  }
}